# Скопируйте в `.env` в корне репозитория и заполните значения.
# Файл не коммитится (см. `.gitignore`).

# Порт HTTP API (по умолчанию 3001)
PORT=3001

# Входящий webhook Bitrix24: Настройки → Разработчикам → Входящий вебхук
# Формат: https://<портал>.bitrix24.ru/rest/<user_id>/<secret>/
B24_WEBHOOK_URL=

# Разрешённые origin для CORS (через запятую). Пусто или * — разрешить всё (удобно для разработки).
CORS_ORIGIN=

# Базовый URL API для браузера (продакшен: полный URL бэкенда). Пусто — относительные пути `/api/...`.
VITE_API_BASE=
